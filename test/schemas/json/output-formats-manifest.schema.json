{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mapequation.org/infomap/test-schemas/output-formats-manifest.schema.json",
  "type": "object",
  "required": ["resultOrder", "formats"],
  "additionalProperties": false,
  "properties": {
    "resultOrder": {
      "type": "array",
      "items": { "type": "string" }
    },
    "formats": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["optionName", "files"],
        "additionalProperties": false,
        "properties": {
          "optionName": { "type": "string" },
          "files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["key", "name", "isStates", "suffix", "extension", "mimeType"],
              "additionalProperties": false,
              "properties": {
                "key": { "type": "string" },
                "name": { "type": "string" },
                "isStates": { "type": "boolean" },
                "suffix": { "type": "string" },
                "extension": { "type": "string" },
                "mimeType": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
