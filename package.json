{
  "name": "@mapequation/infomap",
  "version": "2.10.1",
  "description": "Infomap network clustering algorithm",
  "browser": "./index.umd.js",
  "module": "./index.js",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "*.js",
    "*.cjs",
    "*.d.ts",
    "*.map",
    "LICENSE_GPLv3.txt"
  ],
  "main": "./index.cjs",
  "types": "./index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs",
      "default": "./index.js"
    },
    "./react": {
      "types": "./react.d.ts",
      "import": "./react.js",
      "require": "./react.cjs",
      "default": "./react.js"
    },
    "./result": {
      "types": "./result.d.ts",
      "import": "./result.js",
      "require": "./result.cjs",
      "default": "./result.js"
    },
    "./arguments": {
      "types": "./arguments.d.ts",
      "import": "./arguments.js",
      "require": "./arguments.cjs",
      "default": "./arguments.js"
    },
    "./filetypes": {
      "types": "./filetypes.d.ts",
      "import": "./filetypes.js",
      "require": "./filetypes.cjs",
      "default": "./filetypes.js"
    },
    "./network": {
      "types": "./network.d.ts",
      "import": "./network.js",
      "require": "./network.cjs",
      "default": "./network.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:package",
    "build:package": "rollup -c interfaces/js/rollup.config.mjs && tsc -p interfaces/js/tsconfig.build.json",
    "build:worker-output-formats": "node interfaces/js/scripts/write-worker-output-formats.mjs",
    "typecheck": "tsc -p interfaces/js/tsconfig.json --noEmit",
    "lint": "biome lint --error-on-warnings interfaces/js",
    "test:unit": "vitest run --config interfaces/js/vitest.config.ts",
    "test:browser": "playwright test --config interfaces/js/playwright.config.ts",
    "test:package": "node interfaces/js/scripts/verify-package.mjs",
    "format": "biome format --write package.json interfaces/js",
    "format:check": "biome format package.json interfaces/js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mapequation/infomap.git"
  },
  "keywords": [
    "map equation",
    "network analysis",
    "community detection",
    "clustering algorithm"
  ],
  "author": {
    "name": "mapequation",
    "email": "mapequation@gmail.com",
    "url": "https://www.mapequation.org/about.html"
  },
  "maintainers": [
    {
      "name": "Daniel Edler"
    },
    {
      "name": "Anton Holmgren"
    },
    {
      "name": "Martin Rosvall"
    }
  ],
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/mapequation/infomap/issues"
  },
  "homepage": "https://www.mapequation.org/infomap/",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "jsdom": "^26.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.5",
    "rollup": "^4.52.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "react": ">=16.9.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
