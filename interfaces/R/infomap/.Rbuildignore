^\.Rproj\.user$
^.*\.Rproj$
^_pkgdown\.yml$
^pkgdown$
^docs$
^\.github$
^cran-comments\.md$
^CRAN-RELEASE$
^src/Makevars\.in$
^src/Makevars\.win\.in$
^src/symbols\.rds$
^configure\.win$
^bootstrap\.R$
# Compiled artifacts must never reach the source tarball. .Rbuildignore only
# filters at the initial copy (catching a dirty in-place source tree); the
# objects that the vignette install creates *during* the build are removed by
# the cleanup script instead.
\.o$
\.so$
\.dll$
\.dylib$
